{
  "compilerOptions": {
    "checkJs": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "dist", "tests", "backup"]
}
